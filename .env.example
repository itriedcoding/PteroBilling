APP_NAME=PteroBilling
APP_ENV=production
APP_DEBUG=false
APP_URL=https://billing.example.com
APP_DOMAIN=billing.example.com
APP_SECURE=true
APP_KEY=change-this-to-a-random-32-char-string

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pterobilling
DB_USERNAME=root
DB_PASSWORD=

PTERODACTYL_URL=https://panel.example.com
PTERODACTYL_API_KEY=change-this-to-your-ptero-api-key

STRIPE_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PUBLIC_KEY=pk_live_xxxxx

PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx
PAYPAL_MODE=live

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=PteroBilling

JWT_SECRET=change-this-to-a-random-string